{
  "id": "openclaw-health",
  "name": "OpenClaw Health",
  "summary": "Checks whether a local OpenClaw-compatible runtime is reachable and whether the configured model appears available.",
  "scope": "local-command",
  "surfaces": [
    "core"
  ],
  "reads": [
    "program.md",
