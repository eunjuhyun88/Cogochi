  "agents": [
    {
      "id": "asset-curator",
      "name": "Asset Curator",
      "role": "researcher",
      "summary": "Audits itch.io asset packs, records licensing constraints, and prepares one coherent runtime family for Cogochi.",
      "surfaces": [
        "core"
      ],
      "manifestPath": "agents/asset-curator.json",
      "outputs": [
        "asset-shortlist",
        "import-manifest"
      ],
      "handoff": "asset-shortlist",
      "public": true
    },
    {
      "id": "autoresearch-director",
      "name": "Autoresearch Director",
      "role": "planner",
      "summary": "Reads the founder goal, scorecards, and bottlenecks to choose the next bounded experiment for Cogochi.",
      "surfaces": [
        "core"
      ],
      "manifestPath": "agents/autoresearch-director.json",
      "outputs": [
        "task-selection",
        "checkpoint"
      ],
      "handoff": "checkpoint",
      "public": true
    },
    {
      "id": "battle-researcher",
      "name": "Battle Researcher",
      "role": "implementer",
      "summary": "Improves deterministic battle evaluation, explanation quality, and benchmark readiness for chart scenarios.",
      "surfaces": [
        "core"
      ],
      "manifestPath": "agents/battle-researcher.json",
      "outputs": [
        "benchmark-change",
        "brief"
      ],
      "handoff": "brief",
      "public": true
    },
    {
      "id": "field-loop-builder",
      "name": "Field Loop Builder",
      "role": "implementer",
      "summary": "Builds the top-down field route, party follow behavior, interact nodes, and battle-gate transitions that make Cogochi feel like a real web game.",
      "surfaces": [
        "core"
      ],
      "manifestPath": "agents/field-loop-builder.json",
      "outputs": [
        "field-surface-change",
        "brief"
      ],
      "handoff": "brief",
      "public": true
    },
    {
      "id": "implementer",
      "name": "Implementer",
      "role": "implementer",
      "summary": "Implements code changes against declared context and ownership boundaries.",
      "surfaces": [
        "core"
      ],
      "manifestPath": "agents/implementer.json",
      "outputs": [
        "code-change",
        "brief"
      ],
      "handoff": "brief",
      "public": true
    },
    {
      "id": "memory-tuner",
      "name": "Memory Tuner",
      "role": "implementer",
      "summary": "Improves doctrine capture, memory writeback, retrieval policy, and the post-match reflection loop.",
      "surfaces": [
        "core"
      ],
      "manifestPath": "agents/memory-tuner.json",
      "outputs": [
        "memory-change",
        "brief"
      ],
      "handoff": "brief",
      "public": true
    },
    {
      "id": "planner",
      "name": "Planner",
      "role": "planner",
      "summary": "Plans and routes ambiguous work before implementation begins.",
      "surfaces": [
        "core"
      ],
      "manifestPath": "agents/planner.json",
      "outputs": [
        "execution-plan",
        "checkpoint"
      ],
      "handoff": "checkpoint",
      "public": true
    },
    {
      "id": "raising-ux-shipper",
      "name": "Raising UX Shipper",
      "role": "implementer",
      "summary": "Builds the roster, agent detail, training, and reflection surfaces that make capability changes visible to the player.",
      "surfaces": [
        "core"
      ],
      "manifestPath": "agents/raising-ux-shipper.json",
      "outputs": [
        "surface-change",
        "brief"
      ],
      "handoff": "brief",
      "public": true
    },
    {
      "id": "reviewer",
      "name": "Reviewer",
      "role": "reviewer",
      "summary": "Reviews work for drift, risk, and boundary compliance.",
      "surfaces": [
        "core"
      ],
      "manifestPath": "agents/reviewer.json",
      "outputs": [
        "review-findings",
        "handoff"
      ],
      "handoff": "handoff",
      "public": true
    },
    {
      "id": "runtime-memory-architect",
      "name": "Runtime Memory Architect",
      "role": "implementer",
      "summary": "Maintains the Memento-style memory/runtime split, runtime bundle scripts, and OpenClaw-facing adapter contracts.",
      "surfaces": [
        "core"
      ],
      "manifestPath": "agents/runtime-memory-architect.json",
      "outputs": [
        "runtime-change",
        "brief"
      ],
      "handoff": "brief",
      "public": true
    },
    {
      "id": "ship-reviewer",
      "name": "Ship Reviewer",
      "role": "reviewer",
      "summary": "Checks that candidate changes satisfy hard gates, score better than baseline, and do not drift away from the founder goal.",
      "surfaces": [
        "core"
      ],
      "manifestPath": "agents/ship-reviewer.json",
      "outputs": [
        "accept-reject",
        "handoff"
      ],
      "handoff": "handoff",
      "public": true
    }
